# Coach Agent Template — Environment Variables
# Copy this file to .env and fill in your values

# Coach Configuration
# Path to the coach configuration JSON file (relative to project root or absolute)
COACH_CONFIG_PATH=./config/nurogym.json

# Client-side coach configuration (used in browser)
# These should match your nurogym.json values
NEXT_PUBLIC_COACH_NAME=NuroCoach
NEXT_PUBLIC_COACH_DOMAIN=Neurodivergent Fitness & Wellness
NEXT_PUBLIC_STORAGE_KEY_PREFIX=nurogym-agent

# Frontend URL
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3003

# LLM Provider (choose one: openai, azure_openai, openrouter, gemini)
SERVICE_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# Google Gemini (default for NuroGym — fast, capable, cost-effective)
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_ENDPOINT=
AZURE_OPENAI_CHAT_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=

# ChromaDB (use localhost:8003 for local dev; Docker containers use internal port 8000 via docker-compose)
CHROMA_DATABASE_URL=http://localhost:8003
CHROMA_COLLECTION_NAME=nurogym_knowledge

# Documents — comma-separated folders embedded into ChromaDB for RAG (curriculum = knowledge base; memory = optional workspace notes)
DOCUMENTS_FOLDER=curriculum,memory
CHUNK_SIZE=768
CHUNK_OVERLAP=150

# SearXNG Web Search
SEARXNG_URL=https://xng.quest.ac

# Public API (v1) — Optional
# Set V1_API_KEY to require authentication for /api/v1/* endpoints
# Leave empty to allow unauthenticated access
V1_API_KEY=

# CORS — Comma-separated list of allowed origins for /api/v1/* and /embed
# Use * to allow all origins (default)
ALLOWED_ORIGINS=*
